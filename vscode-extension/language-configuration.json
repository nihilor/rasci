{
  "comments": {
    "lineComment": "%%"
  },
  "brackets": [
    ["[", "]"]
  ],
  "autoClosingPairs": [
    { "open": "[", "close": "]" },
    { "open": "\"", "close": "\"" }
  ],
  "surroundingPairs": [
    ["[", "]"],
    ["\"", "\""]
  ],
  "indentationRules": {
    "increaseIndentPattern": "^(\\s*)(roles|tasks|rules|group)\\s*:.*$",
    "decreaseIndentPattern": "^\\s{0,1}[^\\s]"
  }
}